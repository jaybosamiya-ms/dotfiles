#!/bin/bash

# Originally from https://github.com/PeterFidelman/distracked
# Modifications by f0xtr0t:
# - Use XDG Base Directory Specification for storage location.
# - Track the active stack via a `.current` pointer file instead of relying
#   on filesystem mtime ordering (which was fragile under external touches).
# - `pop` now also prints the new top-of-stack ("next") after popping, so
#   you can see what to work on next. Skipped when the stack is now empty.
# - `push` now clears the yank buffer when it restored from yank (i.e. no
#   explicit argument was given), so a yanked item is only restorable once.
#   An arg-supplied push leaves `.yank` untouched.
# - Replace the fragile `docstr`-grep pipeline with an explicit subcmd table
#   (`subcmd_table()`), used by `usage`. Inline `docstr` calls are now
#   no-ops but kept for readability.
# - Multi-stack listings (`heads`, `all`, and bare `dt`) now highlight the
#   label of the currently active stack in bold + bright cyan via ANSI.
# - Bare `dt` (no args) now prints `heads` (top of every stack) only; it no
#   longer falls through to usage (previously: showed current stack head).
# - `head` now prefixes output with the current stack name, matching the
#   format already used by `cat`/`all`/`heads`.
# - `edit` now uses `$VISUAL`, falling back to `$EDITOR`; errors out if
#   neither is set. Previously invoked the Debian-specific `editor` command.
# - Make `pop` less silent:
#   - Print the popped item to stdout.
#   - Remind on stderr that the item is yanked and can be restored via `push`.
#   - Refuse to pop from an empty stack instead of silently no-op'ing.
# - Make `rm` non-silent and less dangerous:
#   - Refuse to delete non-empty stacks unless `-f` is passed.
#   - Refuse to delete internal dotfiles (e.g. `.current`, `.yank`).
#   - Require an explicit stack name argument.
#   - Announce deletion and auto-switch-to-main on stderr.

DISTRACKED_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/distracked"

init() {
    if [[ ! -e "$DISTRACKED_DIR" ]]; then mkdir -p "$DISTRACKED_DIR"; fi
    cd "$DISTRACKED_DIR" || exit 1
    if [[ ! -e "main" ]]; then touch "main"; fi
    if [[ ! -e ".current" ]]; then echo "main" > .current; fi
    # The rest of the script will assume that:
    # - We are in the configuration directory.
    # - There is at least one stack, called "main".
    # - `.current` holds the name of the active stack.
}

current_stack() {
    cat .current
}

set_current() {
    echo "$1" > .current
}

# List stack files (excludes dotfiles like .current and .yank).
stack_files() {
    ls
}

stack_list() {
    local current
    current="$(current_stack)"
    for f in $(stack_files); do
        if [[ "$f" == "$current" ]]; then
            echo "* $f"
        else
            echo "  $f"
        fi
    done
}

stack_head() {
    tail -n 1 "$*"
}

# Return a "-- name --" label, highlighted when name matches the active stack.
# Active: bold + bright cyan. Used by multi-stack listings (`heads`, `all`,
# bare `dt`) to highlight the current stack.
fmt_stack_label() {
    local name="$1"
    if [[ "$name" == "$(current_stack)" ]]; then
        printf '\033[1;96m-- %s --\033[0m' "$name"
    else
        printf -- '-- %s --' "$name"
    fi
}

docstr() {
    true
}

do_subcmd() {
    subcmd="$1"
    shift

    init
    case "$subcmd" in
    "all"   ) docstr "display entire contents of all stacks";
              for f in $(stack_files); do echo; fmt_stack_label "$f"; echo; echo -n '* '; tac "$f"; done;;
    "cat"   ) docstr "display entire contents of current stack";
              echo -ne "-- $(current_stack) --\n* " ; tac "$(current_stack)" ;;
    "edit"  ) docstr "open all stacks in text editor for bulk modification";
              ed="${VISUAL:-$EDITOR}"
              if [[ -z "$ed" ]]; then
                  echo "error: neither \$VISUAL nor \$EDITOR is set" >&2
                  return 1
              fi
              "$ed" $(stack_files) ;;
    "head"  ) docstr "display top of stack";
              echo -ne "-- $(current_stack) --\n* " ; stack_head "$(current_stack)" ;;
    "heads"  ) docstr "display tops of all stacks";
              for f in $(stack_files); do echo; fmt_stack_label "$f"; echo; echo -n '* '; stack_head "$f"; done;;
    "help"  ) docstr "display this message";
              return 1 ;;
    "ls"    ) docstr "list all stacks";
              stack_list ;;
    "pop"   ) docstr "remove top of stack";
              current="$(current_stack)"
              if [[ ! -s "$current" ]]; then
                  echo "error: stack '$current' is empty; nothing to pop" >&2
                  return 1
              fi
              stack_head "$current" > .yank
              sed -i '$d' "$current"
              echo "popped: $(cat .yank)"
              echo "(yanked; use 'dt push' to restore)" >&2
              if [[ ! -s "$current" ]]; then
                  echo "note: stack '$current' is now empty; use 'rm $current' to delete it" >&2
              else
                  echo -ne "\nnext -- $current --\n* " ; stack_head "$current"
              fi ;;
    "push"  ) docstr "add given (default: last popped) item at top of stack";
              used_yank=0
              if [[ -n "$*" ]]; then
                  item="$*"
              elif [[ -s .yank ]]; then
                  item="$(cat .yank)"
                  used_yank=1
              else
                  echo "error: nothing to push (no args and no yanked item)" >&2
                  return 1
              fi
              echo "$item" >> "$(current_stack)"
              if [[ "$used_yank" -eq 1 ]]; then
                  : > .yank
              fi ;;
    "rm"    ) docstr "delete given stack (refuses non-empty stacks unless -f)";
              force=0
              if [[ "$1" == "-f" ]]; then force=1; shift; fi
              target="$*"
              if [[ -z "$target" ]]; then
                  echo "error: rm requires a stack name" >&2
                  return 1
              fi
              if [[ "$target" == .* ]]; then
                  echo "error: refusing to rm internal file: $target" >&2
                  return 1
              fi
              if [[ ! -e "$target" ]]; then
                  echo "error: no such stack: $target" >&2
                  return 1
              fi
              if [[ -s "$target" && "$force" -ne 1 ]]; then
                  echo "error: stack '$target' is not empty ($(wc -l < "$target") item(s))" >&2
                  echo "       use 'dt rm -f $target' to force, or pop items first" >&2
                  return 1
              fi
              rm "$target"
              echo "deleted stack: $target" >&2
              if [[ "$(current_stack)" == "$target" ]]; then
                  if [[ ! -e "main" ]]; then touch "main"; fi
                  set_current "main"
                  echo "switched to: main" >&2
              fi ;;
    "switch") docstr "switch to given stack, creating it if necessary";
              touch "$*" ; set_current "$*" ; stack_list ;;
    ""      ) for f in $(stack_files); do echo; fmt_stack_label "$f"; echo; echo -n '* '; stack_head "$f"; done
              echo ;;
    *)
        # Unrecognized subcmd
        return 1
        ;;
    esac
    return 0
}

usage() {
    echo "usage: $0 [subcmd]"
    subcmd_table | sed 's/^/  /'
    exit 1
}

# Emit "subcmd<TAB>description" lines, aligned via `column`.
# Source of truth is an explicit table (the previous `docstr`-parsing trick
# was too fragile once case bodies grew beyond a single line).
subcmd_table() {
    column -t -s $'\t' <<'EOF'
all	display entire contents of all stacks
cat	display entire contents of current stack
edit	open all stacks in text editor for bulk modification
head	display top of stack
heads	display tops of all stacks
help	display this message
ls	list all stacks
pop	remove top of stack (reports the popped item; restorable via push)
push	add given (default: last popped) item at top of stack
rm	delete given stack (refuses non-empty stacks unless -f)
switch	switch to given stack, creating it if necessary
EOF
}

# Script entry point
do_subcmd "$@"
if [[ "$?" -ne 0 ]]
then
    usage
fi

